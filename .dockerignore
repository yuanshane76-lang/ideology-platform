# Python 缓存与编译产物
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# 虚拟环境
venv/
.venv/
env/

# Qdrant 本地数据（通过 volume 挂载，不打入镜像）
Qdrant/

# 缓存与临时文件
cache/
brainstorming/
ui-redesign/
.pytest_cache/

# 输出产物（运行时生成）
outputs/
downloads/

# 数据库文件（运行时生成）
*.db
chat_history.db

# 日志
*.log

# 环境变量（敏感信息，不打入镜像）
.env
.env.local
.env.*.local

# IDE 配置
.vscode/
.idea/
.qoder/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Node（仅 docx 纯 JS 包，服务端不用）
node_modules/

# 测试
tests/

# 文档与脚本（非运行必需）
docs/
scripts/
*.md
README.md
LICENSE
deploy_autodl.sh
deploy_to_server.ps1
ideology.service
package.json
package-lock.json

# 每日要闻数据（运行时生成）
